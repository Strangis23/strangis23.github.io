# SteamPipe upload (desktop/scripts/upload-steam.sh)
SWD_STEAM_USER=your_steam_partner_username
SWD_STEAM_PASS=your_steam_password_or_token

# Steam App ID (dev: 480 Spacewar; replace with your partner App ID for production)
STEAM_APP_ID=480

# Optional: path to steamcmd if not on PATH
# STEAMCMD=/path/to/steamcmd

# Desktop dev / build (see desktop/README.md)
# SWD_DEVTOOLS=1
# SWD_ALLOW_RESIZE=1
# SWD_FIXED_WINDOW=1
# SWD_REQUIRE_STEAM=1
# SWD_REQUIRE_STEAM=0   # packaged build: allow running without Steam (testing only)
