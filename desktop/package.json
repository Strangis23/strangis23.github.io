{
  "name": "stackwave-defense",
  "productName": "Stackwave Defense",
  "version": "1.0.0",
  "description": "Stackwave Defense — deck-builder tower defense",
  "main": "main.js",
  "author": "Stackwave Defense",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "start:steam": "STEAM_APP_ID=480 electron .",
    "icons": "bash scripts/generate-icons.sh",
    "pack": "electron-builder --dir",
    "build": "npm run icons && electron-builder --win --linux",
    "build:win": "npm run icons && electron-builder --win",
    "build:linux": "npm run icons && electron-builder --linux",
    "build:release": "npm run icons && electron-builder --win --linux",
    "stage:steam": "bash scripts/stage-steam-content.sh",
    "steam:upload": "bash scripts/upload-steam.sh",
    "steam:ship": "npm run build:release && npm run stage:steam"
  },
  "build": {
    "appId": "com.stackwave.defense",
    "productName": "Stackwave Defense",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "steam-bridge.js",
      "window-config.js",
      "../index.html",
      "../highscores.html",
      "../privacy.html",
      "../styles.css",
      "../manifest.json",
      "../js/**/*",
      "../assets/**/*",
      "../audio/**/*",
      "../steam/**/*",
      "../steam_appid.txt",
      "!../github-pages-root/**",
      "!../desktop/dist/**",
      "!../desktop/node_modules/**",
      "!../sw.js",
      "!../ads.txt"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/steamworks.js/**"
    ],
    "win": {
      "target": ["zip", "portable"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["tar.gz"],
      "icon": "build/icon.png",
      "category": "Game",
      "executableName": "stackwave-defense"
    }
  },
  "dependencies": {
    "steamworks.js": "^0.4.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
